# ===== エッジデバイス設定 =====
# 各Raspberry Piごとに異なる値を設定してください

# このラズパイの識別ID（ras_01 〜 ras_09）
RASPBERRY_PI_ID=ras_01

# Flaskサーバーの環境データ送信エンドポイント
API_ENDPOINT_URL=https://your-server.ngrok-free.dev/api/add_env_data

# センサー計測設定
SENSOR_SCAN_COUNT=30        # 1回あたりのスキャン回数
SENSOR_SCAN_INTERVAL=1      # スキャン間隔（秒）

# API通信設定
API_TIMEOUT=10              # リクエストタイムアウト（秒）
RETRY_DELAY=5               # エラー時の再試行間隔（秒）
