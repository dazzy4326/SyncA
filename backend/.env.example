# ===== Flask サーバー設定 =====
FLASK_DEBUG=True
FLASK_SECRET_KEY=your-secret-key-change-in-production

# ===== データベース設定 =====
DB_USER=flask_reader
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_NAME=sensor_db

# ===== エッジデバイス設定 (env_get_api.py 用) =====
RASPBERRY_PI_ID=ras_02
API_ENDPOINT_URL=https://your-server.ngrok-free.dev/api/add_env_data
SENSOR_SCAN_COUNT=30
SENSOR_SCAN_INTERVAL=1
API_TIMEOUT=10
RETRY_DELAY=5
